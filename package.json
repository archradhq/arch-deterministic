{
  "name": "@archrad/deterministic",
  "version": "0.1.0",
  "description": "Deterministic architecture compiler & linter. OSS: structural validation + basic architecture linting (rule-based, deterministic); FastAPI/Express export; OpenAPI document-shape; golden Docker/Makefile — no LLM.",
  "keywords": [
    "archrad",
    "openapi",
    "fastapi",
    "express",
    "deterministic",
    "codegen",
    "docker",
    "cli"
  ],
  "homepage": "https://github.com/archradhq/arch-deterministic#readme",
  "bugs": {
    "url": "https://github.com/archradhq/arch-deterministic/issues"
  },
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/archradhq/arch-deterministic.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "archrad": "./dist/cli.js"
  },
  "files": [
    "dist",
    "fixtures",
    "schemas",
    "scripts",
    "LICENSE",
    "README.md",
    "llms.txt",
    "docs",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
